{
    "name": "n8n-nodes-easyship-shipment",
    "version": "0.1.0",
    "description": "An n8n community node for creating Easyship shipments and returning PDF labels",
    "author": {
        "name": "Jeremy Teeter",
        "email": "jeremyteeter@users.noreply.github.com"
    },
    "license": "MIT",
    "keywords": ["n8n-community-node-package", "n8n", "easyship", "shipping"],
    "scripts": {
        "build": "n8n-node build",
        "dev": "n8n-node dev",
        "lint": "n8n-node lint",
        "lint:fix": "n8n-node lint --fix",
        "test": "npm run build && node --test tests/*.test.cjs",
        "prepublishOnly": "n8n-node prerelease"
    },
    "files": ["dist"],
    "n8n": {
        "n8nNodesApiVersion": 1,
        "strict": true,
        "credentials": ["dist/credentials/EasyshipApi.credentials.js"],
        "nodes": ["dist/nodes/Easyship/Easyship.node.js"]
    },
    "devDependencies": {
        "@n8n/node-cli": "0.36.2",
        "eslint": "9.29.0",
        "prettier": "3.8.3",
        "typescript": "5.9.3"
    },
    "peerDependencies": { "n8n-workflow": "*" }
}
